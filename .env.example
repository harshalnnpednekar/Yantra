# --- FRONTEND (Vite Prefix) ---
VITE_API_BASE_URL=http://localhost:8000
VITE_AI_SERVER_URL=http://localhost:8001

# --- BACKEND (Cloud Databases) ---
# Neon (Postgres)
# Get this from: https://console.neon.tech/
NEON_DATABASE_URL="postgres://user:password@hostname/dbname?sslmode=require"

# Supabase (Postgres & Auth)
# Get this from: https://supabase.com/dashboard/project/settings/api
SUPABASE_URL="https://your-project-id.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# MongoDB Atlas
# Get this from: https://cloud.mongodb.com/
MONGODB_ATLAS_URI="mongodb+srv://user:password@cluster.mongodb.net/dbname?retryWrites=true&w=majority"

# --- AI / ML ---
# OpenAI / Anthropic / Gemini
OPENAI_API_KEY="sk-..."
GEMINI_API_KEY="..."

# --- SECURITY ---
SECRET_KEY="replace-this-with-a-very-long-random-string"
JWT_ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=60
